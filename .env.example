# ============================================
# REQUIRED CONFIGURATION
# ============================================

# Database connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auth_flow

# JWT secret for token signing (use a long, random string)
JWT_SECRET=replace-with-a-long-random-secret-key-min-32-chars

# ============================================
# PAYSTACK CONFIGURATION (Webhooks & Payments)
# ============================================

# Paystack API Keys
# Get from: https://dashboard.paystack.com/settings/developers
# Use sk_test_* and pk_test_* for testing
# Use sk_live_* and pk_live_* for production
PAYSTACK_SECRET_KEY=sk_test_your_secret_key
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key

# Webhook URL (configure this in Paystack Dashboard)
# When testing locally with ngrok: https://xxxxx.ngrok.io/api/wallet/webhook
# In production: https://yourdomain.com/api/wallet/webhook
PAYSTACK_WEBHOOK_URL=http://localhost:5000/api/wallet/webhook

# ============================================
# PAYMENT SERVICE INTEGRATIONS
# ============================================

# OneCard Nigeria (for utility bills, airtime, data)
ONECARD_API_BASE_URL=https://api.onecard.io
ONECARD_API_USERNAME=your_onecard_username
ONECARD_API_PASSWORD=your_onecard_password

# OneBigPie (for vouchers and subscriptions)
ONEBIGPIE_API_BASE_URL=https://api.onebigpie.io
ONEBIGPIE_API_KEY=your_onebigpie_api_key

# Ridera (for ride-sharing)
RIDERA_API_BASE_URL=https://api.ridera.io
RIDERA_API_KEY=your_ridera_api_key

# ============================================
# SERVER CONFIGURATION
# ============================================

# Server port (default: 5000)
PORT=5000

# Environment: development, production, test
NODE_ENV=development

# CORS allowed origins (comma-separated)
CORS_ORIGIN=http://localhost:5173,http://localhost:5000

# Express session secret (use a long random string)
SESSION_SECRET=your-session-secret-key

# ============================================
# OPTIONAL: EMAIL CONFIGURATION
# ============================================

# For sending password reset, payment confirmations, etc.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@yourdomain.com

# ============================================
# OPTIONAL: LOGGING & DEBUGGING
# ============================================

# Log level: debug, info, warn, error (default: info)
# LOG_LEVEL=info

# Enable detailed webhook logging for debugging
# DEBUG_WEBHOOKS=true

# ============================================
# PAYSTACK WEBHOOK SETUP GUIDE
# ============================================
# 
# 1. Get your Paystack API keys from dashboard
# 2. Set PAYSTACK_SECRET_KEY and PAYSTACK_PUBLIC_KEY above
# 3. In Paystack Dashboard: Settings → API Keys & Webhooks
# 4. Set Webhook URL to your domain + /api/wallet/webhook
# 5. Enable these webhook events:
#    - charge.success (for online & DVA payments)
#    - charge.failed (optional, for failed payments)
#    - dedicatedaccount.assign.success (for DVA assignment)
# 6. Your server will automatically credit wallets when users pay!
#
# Local Testing:
#   npm install -g ngrok
#   ngrok http 5000
#   Update webhooks URL in Paystack to: https://xxxxx.ngrok.io/api/wallet/webhook
#   Run: node webhook-test.js test-all
#
# See PAYSTACK_WEBHOOK_GUIDE.md for detailed documentation

